{
  "name": "airalo-cypress-tests",
  "version": "1.0.0",
  "description": "Cypress UI tests for Airalo",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run && npx mochawesome-merge mochawesome-report/*.json > mochawesome-report/report.json && npx marge mochawesome-report/report.json --reportDir mochawesome-report --inline",
    "cy:run:headed": "cypress run --headed --browser chrome",
    "cy:run:sanity": "cypress run --spec 'cypress/integration/Sanity/**' --headed --browser chrome",
    "check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint --fix ."
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/eslint-parser": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-prettier": "^5.0.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^3.0.3"
  },
  "dependencies": {
    "cypress": "^13.3.0",
    "dotenv": "^16.3.1"
  }
}
