{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@controllers/*": ["./src/controllers/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@app-types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"],
      "@context": ["./src/context/context"],
      "@interfaces": ["./src/interfaces/index"],
      "@interfaces/*": ["./src/interfaces/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "fixtures/**/*.ts", "jest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
